# MKLanLocal — Environment Configuration
# Copy this file to .env and fill in all CHANGE_ME values before starting.
# NEVER commit .env to git.

# ── Application ────────────────────────────────────────────────
APP_NAME=MKLanLocal
APP_ENV=production

# ── Security (REQUIRED) ────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
COOKIE_SECURE=false   # set true when served over HTTPS

# ── Seed Users ────────────────────────────────────────────────
# These users are created on first startup. Passwords are hashed with Argon2.
# Change all three before the first run.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_admin_password

CURATOR_USERNAME=curator
CURATOR_PASSWORD=CHANGE_ME_curator_password

GUEST_USERNAME=guest
GUEST_PASSWORD=CHANGE_ME_guest_password

# ── Database ───────────────────────────────────────────────────
POSTGRES_DB=media_indexer
POSTGRES_USER=media_indexer
POSTGRES_PASSWORD=CHANGE_ME_db_password
DATABASE_URL=postgresql+psycopg://media_indexer:CHANGE_ME_db_password@db:5432/media_indexer

# ── Networking ─────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=/api
INTERNAL_API_BASE_URL=http://backend:8000

# ── Storage paths (inside containers — do not change unless you know what you're doing)
PREVIEW_ROOT=/workspace/storage/previews
ALLOWED_SOURCE_ROOTS=/data/sources
UPLOAD_SOURCE_ROOT=/data/sources/upload

# ── Worker ────────────────────────────────────────────────────
WORKER_POLL_INTERVAL_SECONDS=5
CLIP_ENABLED=true
CLIP_MODEL_ID=openai/clip-vit-base-patch32
CLIP_DEVICE=cpu         # set to cuda if you have a GPU

# ── Tuning ────────────────────────────────────────────────────
MAX_THUMBNAIL_SIZE=512
DUPLICATE_PHASH_THRESHOLD=8
SEMANTIC_SIMILARITY_THRESHOLD=0.22
SEMANTIC_NEIGHBOR_LIMIT=24
PREVIEW_CACHE_MAX_MB=2048
ACCESS_TOKEN_TTL_SECONDS=86400

# ── Source paths on the HOST (add your own) ───────────────────
# Uncomment and set these, then add matching bind mounts in infra/docker-compose.yml
# SOURCE_PATH_OUTPUT=/path/to/your/output/folder
# SOURCE_PATH_PHOTOS=/path/to/your/photos
