#!/usr/bin/env python3
from __future__ import annotations

import json
import sys
from datetime import datetime, timezone
from pathlib import Path


REPO_ROOT = Path(__file__).resolve().parents[1]
BACKEND_SRC = REPO_ROOT / "backend" / "src"

if str(BACKEND_SRC) not in sys.path:
    sys.path.insert(0, str(BACKEND_SRC))

from media_indexer_backend.platform.registry import discover_module_manifests  # noqa: E402
from media_indexer_backend.platform.service import PLATFORM_API_VERSION  # noqa: E402


OUTPUT_PATHS = [
    REPO_ROOT / "backend" / "generated" / "addon-manifest-registry.json",
    REPO_ROOT / "frontend" / "generated" / "addon-manifest-registry.json",
]


def serialize_manifest(manifest) -> dict[str, object]:
    return {
        "id": manifest.id,
        "name": manifest.name,
        "version": manifest.version,
        "description": manifest.description,
        "platform_api_version": manifest.platform_api_version,
        "source_ref": manifest.source_ref,
        "dependencies": manifest.dependencies,
        "permissions": manifest.permissions,
        "backend_entrypoint": manifest.backend_entrypoint,
        "worker_entrypoint": manifest.worker_entrypoint,
        "frontend_entrypoint": manifest.frontend_entrypoint,
        "backend_migrations": manifest.backend_migrations,
        "api_mount": manifest.api_mount,
        "user_mount": manifest.user_mount,
        "admin_mount": manifest.admin_mount,
        "nav_label": manifest.nav_label,
        "nav_href": manifest.nav_href,
        "admin_nav_label": manifest.admin_nav_label,
        "admin_nav_href": manifest.admin_nav_href,
        "settings_schema": [field.model_dump() for field in manifest.settings_fields],
        "manifest_path": manifest.manifest_path,
    }


def main() -> int:
    manifests = [manifest for manifest in discover_module_manifests(repo_root=REPO_ROOT) if manifest.kind == "addon"]
    errors: list[str] = []

    for manifest in manifests:
        if manifest.platform_api_version != PLATFORM_API_VERSION:
            errors.append(
                f"{manifest.id}: incompatible platform_api_version {manifest.platform_api_version!r} "
                f"(expected {PLATFORM_API_VERSION!r})"
            )
        if manifest.error:
            errors.append(f"{manifest.id}: {manifest.error}")
        if not manifest.source_ref:
            errors.append(f"{manifest.id}: source_ref is required in addons.toml")
        if not manifest.manifest_path:
            errors.append(f"{manifest.id}: manifest_path is missing")

    payload = {
        "platform_api_version": PLATFORM_API_VERSION,
        "generated_at": datetime.now(tz=timezone.utc).isoformat(),
        "addons": [serialize_manifest(manifest) for manifest in manifests if not manifest.error],
    }

    for output_path in OUTPUT_PATHS:
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")

    if errors:
        print("Addon sync failed:", file=sys.stderr)
        for error in errors:
            print(f" - {error}", file=sys.stderr)
        return 1

    print(f"Synchronized {len(payload['addons'])} addons.")
    for output_path in OUTPUT_PATHS:
        print(f" - wrote {output_path.relative_to(REPO_ROOT)}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
